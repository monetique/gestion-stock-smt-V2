# ============================================
# FICHIER D'EXEMPLE DES VARIABLES D'ENVIRONNEMENT
# ============================================
# Copiez ce fichier vers .env et remplissez les valeurs appropriées
# cp .env.example .env

# ============================================
# VARIABLES REQUISES
# ============================================

# URL de connexion à la base de données PostgreSQL
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?schema=public
# Exemple: postgresql://postgres:mypassword@localhost:5432/stock_management?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/stock_management?schema=public"

# Environnement d'exécution
# Valeurs possibles: development, production, test
NODE_ENV="development"

# ============================================
# VARIABLES OPTIONNELLES
# ============================================

# URL publique de l'API (utilisée dans les emails et les liens)
# Si non définie, utilisera automatiquement l'URL courante
# Exemple: http://localhost:3000 (développement) ou https://votre-domaine.com (production)
NEXT_PUBLIC_API_URL="http://localhost:3000"

# ============================================
# SÉCURITÉ (RECOMMANDÉ EN PRODUCTION)
# ============================================

# Secret pour les sessions (générez une valeur aléatoire sécurisée)
# Pour générer: openssl rand -base64 32
SESSION_SECRET="change-this-to-a-random-secure-string"

# Secret pour JWT - Access Token (OBLIGATOIRE en production)
# Pour générer: openssl rand -base64 32
# Minimum 32 caractères requis
JWT_SECRET="change-this-to-a-random-secure-string-min-32-chars"

# Secret pour JWT - Refresh Token (OBLIGATOIRE en production)
# Pour générer: openssl rand -base64 32
# Minimum 32 caractères requis
JWT_REFRESH_SECRET="change-this-to-a-random-secure-string-min-32-chars"

# ============================================
# CONFIGURATION SMTP (OPTIONNEL)
# ============================================
# Ces variables peuvent aussi être configurées via l'interface web
# dans la page Configuration > Paramètres SMTP

SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL="noreply@example.com"
SMTP_FROM_NAME="Monetique Tunisie - Gestion de Stocks"

# ============================================
# OPTIONS DE DÉVELOPPEMENT (OPTIONNEL)
# ============================================
# Définir à "true" pour désactiver ESLint pendant le build
# ESLINT_DISABLE="true"

# Définir à "true" pour désactiver la validation TypeScript pendant le build
# TYPESCRIPT_DISABLE="true"

# ============================================
# NOTES IMPORTANTES
# ============================================
# 1. Ne commitez JAMAIS le fichier .env dans Git (il est dans .gitignore)
# 2. En production, utilisez des secrets sécurisés pour SESSION_SECRET et JWT_SECRET
# 3. La variable DATABASE_URL est OBLIGATOIRE pour que l'application fonctionne
# 4. En production, assurez-vous que NODE_ENV="production"

